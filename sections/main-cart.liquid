<div class="main-cart color-{{ section.settings.color_scheme }}">
  <div class="page-width">

    <header class="cart-header">
      <h1 class="cart-header__title">{{ 'content.cart_title' | t }}</h1>
      {%- if cart.item_count > 0 -%}
        <p class="cart-header__count">
          ({{ cart.item_count }}
          {{- ' ' -}}
          {%- if cart.item_count == 1 -%}
            {{- 'content.item_count.one' | t: count: cart.item_count -}}
          {%- else -%}
            {{- 'content.item_count.other' | t: count: cart.item_count -}}
          {%- endif -%}
          )
        </p>
      {%- endif -%}
    </header>

    {%- if cart.item_count == 0 -%}

      <div class="cart-empty">
        <p class="cart-empty__text">{{ 'content.your_cart_is_empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">
          {{- 'actions.continue_shopping' | t -}}
        </a>
      </div>

    {%- else -%}

      {%- form 'cart', cart, id: 'cart-form', novalidate: 'novalidate' -%}

        <div class="cart-layout">

          {%- comment -%} Line items {%- endcomment -%}
          <div class="cart-items">
            <div class="cart-items__header">
              <span class="cart-items__col-label">{{ 'sections.main_cart.product' | t }}</span>
              <span class="cart-items__col-label cart-items__col-label--qty">{{ 'content.quantity' | t }}</span>
              <span class="cart-items__col-label cart-items__col-label--total">{{ 'content.price' | t }}</span>
            </div>

            {%- for item in cart.items -%}
              <div class="cart-item" id="cart-item-{{ item.key }}">

                <a class="cart-item__image-link" href="{{ item.url }}" tabindex="-1" aria-hidden="true">
                  {%- if item.image -%}
                    {{
                      item.image
                      | image_url: width: 300
                      | image_tag:
                        loading: 'lazy',
                        class: 'cart-item__image',
                        widths: '150,200,300',
                        sizes: '120px',
                        alt: item.image.alt | default: item.product.title | escape
                    }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'cart-item__image cart-item__image--placeholder' }}
                  {%- endif -%}
                </a>

                <div class="cart-item__details">
                  <a class="cart-item__title" href="{{ item.url }}">{{ item.product.title | escape }}</a>

                  {%- unless item.product.has_only_default_variant -%}
                    <p class="cart-item__variant">{{ item.variant.title | escape }}</p>
                  {%- endunless -%}

                  {%- if item.selling_plan_allocation -%}
                    <p class="cart-item__selling-plan">{{ item.selling_plan_allocation.selling_plan.name | escape }}</p>
                  {%- endif -%}

                  {%- for property in item.properties -%}
                    {%- unless property.last == blank -%}
                      <p class="cart-item__property">
                        {%- unless property.first contains '_' -%}
                          {{ property.first | escape }}:
                        {%- endunless -%}
                        {{ property.last | escape }}
                      </p>
                    {%- endunless -%}
                  {%- endfor -%}

                  {%- if item.original_price != item.final_price -%}
                    <div class="cart-item__discounts">
                      {%- for discount in item.discounts -%}
                        <span class="cart-item__discount-tag">{{ discount.title | escape }}</span>
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>

                <div class="cart-item__quantity-col">
                  <div class="cart-item__qty-wrapper">
                    <button
                      type="button"
                      class="cart-item__qty-btn"
                      data-action="decrease"
                      data-key="{{ item.key }}"
                      aria-label="{{ 'accessibility.decrease_quantity' | t }}"
                    >–</button>
                    <input
                      type="number"
                      name="updates[]"
                      id="qty-{{ item.key }}"
                      value="{{ item.quantity }}"
                      min="0"
                      aria-label="{{ 'accessibility.quantity' | t }}"
                      class="cart-item__qty-input"
                      data-key="{{ item.key }}"
                    >
                    <button
                      type="button"
                      class="cart-item__qty-btn"
                      data-action="increase"
                      data-key="{{ item.key }}"
                      aria-label="{{ 'accessibility.increase_quantity' | t }}"
                    >+</button>
                  </div>
                  <button
                    type="button"
                    class="cart-item__remove"
                    data-key="{{ item.key }}"
                    aria-label="{{ 'accessibility.remove_item' | t: title: item.product.title }}"
                  >
                    {{- 'actions.remove' | t -}}
                  </button>
                </div>

                <div class="cart-item__price-col">
                  {%- if item.original_line_price != item.final_line_price -%}
                    <s class="cart-item__original-price">{{ item.original_line_price | money }}</s>
                  {%- endif -%}
                  <span class="cart-item__final-price">{{ item.final_line_price | money }}</span>
                </div>

              </div>
            {%- endfor -%}
          </div>

          {%- comment -%} Order summary {%- endcomment -%}
          <aside class="cart-summary">
            <div class="cart-summary__inner">
              <h2 class="cart-summary__title">{{ 'sections.main_cart.order_summary' | t }}</h2>

              {%- if cart.cart_level_discount_applications.size > 0 -%}
                <div class="cart-summary__discounts">
                  {%- for discount in cart.cart_level_discount_applications -%}
                    <div class="cart-summary__discount-row">
                      <span>{{ discount.title | escape }}</span>
                      <span>–{{ discount.total_allocated_amount | money }}</span>
                    </div>
                  {%- endfor -%}
                </div>
              {%- endif -%}

              <div class="cart-summary__subtotal-row">
                <span class="cart-summary__label">{{ 'content.cart_subtotal' | t }}</span>
                <span class="cart-summary__amount">{{ cart.total_price | money }}</span>
              </div>

              <p class="cart-summary__shipping-note">
                {%- if shop.taxes_free_checkout and shop.shipping_policy.body != blank -%}
                  {{ 'content.taxes_at_checkout_shipping_at_checkout_with_policy_html' | t: link: shop.shipping_policy.url }}
                {%- elsif shop.taxes_free_checkout -%}
                  {{ 'content.taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
                {%- elsif shop.shipping_policy.body != blank -%}
                  {{ 'content.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                {%- else -%}
                  {{ 'content.shipping_policy' | t }}
                {%- endif -%}
              </p>

              {%- if section.settings.show_cart_note -%}
                <div class="cart-summary__note">
                  <label class="cart-summary__note-label" for="cart-note">
                    {{- 'sections.main_cart.note_label' | t -}}
                  </label>
                  <textarea
                    id="cart-note"
                    name="note"
                    class="cart-summary__note-input"
                    rows="3"
                    placeholder="{{ 'sections.main_cart.note_placeholder' | t }}"
                  >{{ cart.note }}</textarea>
                </div>
              {%- endif -%}

              <button type="submit" name="checkout" class="btn btn--primary cart-summary__checkout">
                {{- 'content.checkout' | t -}}
              </button>

              {%- if additional_checkout_buttons -%}
                <div class="cart-summary__dynamic-checkout">
                  {{ content_for_additional_checkout_buttons }}
                </div>
              {%- endif -%}

              <a href="{{ routes.all_products_collection_url }}" class="cart-summary__continue">
                {{- 'actions.continue_shopping' | t -}}
              </a>
            </div>
          </aside>

        </div>
      {%- endform -%}

    {%- endif -%}

  </div>
</div>

{% stylesheet %}
  .main-cart {
    padding-top: 3rem;
    padding-bottom: 5rem;
  }

  /* Header */
  .cart-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-gray-200);
    margin-bottom: 2.5rem;
  }

  .cart-header__title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--color-black);
  }

  .cart-header__count {
    font-size: 0.875rem;
    color: var(--color-gray-500);
    margin: 0;
  }

  /* Empty state */
  .cart-empty {
    padding: 5rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    text-align: center;
  }

  .cart-empty__text {
    font-size: 1.125rem;
    color: var(--color-gray-500);
    margin: 0;
  }

  /* Layout */
  .cart-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  @media (min-width: 990px) {
    .cart-layout {
      grid-template-columns: 1fr 360px;
      gap: var(--space-12);
    }
  }

  /* Items table */
  .cart-items__header {
    display: none;
  }

  @media (min-width: 750px) {
    .cart-items__header {
      display: grid;
      grid-template-columns: 1fr auto auto;
      gap: var(--space-4);
      padding-bottom: var(--space-3);
      border-bottom: 1px solid var(--color-gray-200);
      margin-bottom: var(--space-2);
    }
  }

  .cart-items__col-label {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gray-500);
  }

  .cart-items__col-label--qty {
    text-align: center;
    min-width: 120px;
  }

  .cart-items__col-label--total {
    text-align: right;
    min-width: 80px;
  }

  /* Cart item */
  .cart-item {
    display: grid;
    grid-template-columns: 100px 1fr;
    grid-template-rows: auto auto;
    gap: var(--space-4);
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--color-gray-200);
  }

  @media (min-width: 750px) {
    .cart-item {
      grid-template-columns: 100px 1fr auto auto;
      grid-template-rows: auto;
      align-items: center;
    }
  }

  .cart-item__image-link {
    grid-row: 1 / 3;
    display: block;
    border: 1px solid var(--color-gray-100);
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }

  @media (min-width: 750px) {
    .cart-item__image-link {
      grid-row: auto;
    }
  }

  .cart-item__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cart-item__image--placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-gray-100);
  }

  .cart-item__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .cart-item__title {
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--color-black);
    text-decoration: none;
    line-height: 1.4;
  }

  .cart-item__title:hover {
    text-decoration: underline;
  }

  .cart-item__variant,
  .cart-item__selling-plan,
  .cart-item__property {
    font-size: 0.8125rem;
    color: var(--color-gray-500);
    margin: 0;
  }

  .cart-item__discounts {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .cart-item__discount-tag {
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.2em 0.5em;
    border: 1px solid var(--color-gray-300);
    color: var(--color-gray-600);
  }

  /* Quantity col */
  .cart-item__quantity-col {
    grid-column: 2;
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  @media (min-width: 750px) {
    .cart-item__quantity-col {
      grid-column: auto;
      flex-direction: column;
      align-items: center;
      gap: var(--space-2);
    }
  }

  .cart-item__qty-wrapper {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-gray-300);
  }

  .cart-item__qty-btn {
    background: none;
    border: none;
    width: 2.25rem;
    height: 2.25rem;
    font-size: 1rem;
    cursor: pointer;
    color: var(--color-black);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cart-item__qty-btn:hover {
    background: var(--color-gray-100);
  }

  .cart-item__qty-input {
    border: none;
    border-left: 1px solid var(--color-gray-300);
    border-right: 1px solid var(--color-gray-300);
    border-radius: 0;
    width: 2.5rem;
    height: 2.25rem;
    text-align: center;
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-black);
    -moz-appearance: textfield;
  }

  .cart-item__qty-input::-webkit-inner-spin-button,
  .cart-item__qty-input::-webkit-outer-spin-button {
    appearance: none;
  }

  .cart-item__remove {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: underline;
    color: var(--color-gray-500);
    cursor: pointer;
  }

  .cart-item__remove:hover {
    color: var(--color-black);
  }

  /* Price col */
  .cart-item__price-col {
    grid-column: 2;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: var(--space-2);
  }

  @media (min-width: 750px) {
    .cart-item__price-col {
      grid-column: auto;
      flex-direction: column;
      align-items: flex-end;
      min-width: 80px;
    }
  }

  .cart-item__original-price {
    font-size: 0.875rem;
    color: var(--color-gray-400);
    text-decoration: line-through;
  }

  .cart-item__final-price {
    font-size: 0.9375rem;
    color: var(--color-black);
  }

  /* Summary */
  .cart-summary__inner {
    border: 1px solid var(--color-gray-200);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    position: sticky;
    top: 5rem;
  }

  .cart-summary__title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0;
    color: var(--color-black);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-gray-200);
  }

  .cart-summary__discounts {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cart-summary__discount-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.875rem;
    color: var(--color-gray-600);
  }

  .cart-summary__subtotal-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
  }

  .cart-summary__label {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-black);
  }

  .cart-summary__amount {
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--color-black);
  }

  .cart-summary__shipping-note {
    font-size: 0.8125rem;
    color: var(--color-gray-500);
    margin: 0;
    line-height: 1.5;
  }

  .cart-summary__shipping-note a {
    color: var(--color-gray-500);
  }

  .cart-summary__note-label {
    display: block;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gray-600);
    margin-bottom: var(--space-2);
  }

  .cart-summary__note-input {
    width: 100%;
    border: 1px solid var(--color-gray-300);
    border-radius: 0;
    padding: var(--space-3);
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-black);
    resize: vertical;
    min-height: 80px;
    box-sizing: border-box;
  }

  .cart-summary__note-input:focus {
    outline: 2px solid var(--color-black);
    outline-offset: 0;
  }

  .cart-summary__checkout {
    width: 100%;
  }

  .cart-summary__dynamic-checkout {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cart-summary__continue {
    font-size: 0.8125rem;
    color: var(--color-gray-500);
    text-align: center;
    text-decoration: underline;
  }

  .cart-summary__continue:hover {
    color: var(--color-black);
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const form = document.getElementById('cart-form');
    if (!form) return;

    function submitForm() {
      form.submit();
    }

    // Quantity stepper buttons
    form.querySelectorAll('.cart-item__qty-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const key = btn.dataset.key;
        const input = form.querySelector('.cart-item__qty-input[data-key="' + key + '"]');
        if (!input) return;
        const current = parseInt(input.value, 10) || 0;
        input.value = btn.dataset.action === 'decrease'
          ? Math.max(0, current - 1)
          : current + 1;
        submitForm();
      });
    });

    // Remove buttons (set qty to 0 and submit)
    form.querySelectorAll('.cart-item__remove').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const key = btn.dataset.key;
        const input = form.querySelector('.cart-item__qty-input[data-key="' + key + '"]');
        if (input) input.value = 0;
        submitForm();
      });
    });

    // Quantity input change
    form.querySelectorAll('.cart-item__qty-input').forEach(function (input) {
      input.addEventListener('change', function () {
        submitForm();
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.main_cart.name",
  "tag": "section",
  "class": "section-main-cart",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_cart_note",
      "label": "t:sections.main_cart.show_cart_note",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "t:sections.main_cart.name"
    }
  ]
}
{% endschema %}
