  <!-- Related Products -->
  {%- assign related_products = collections.all.products | where: 'id', product.id | map: 'id' -%}
  {%- assign all_products = collections.all.products -%}
  {%- assign shown = 0 -%}
  {%- assign has_related = false -%}
  {%- for p in all_products limit: 20 -%}
    {%- if p.id != product.id and shown < 4 -%}
      {%- assign has_related = true -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if has_related -%}
  <div class="rn-related">
    <h2 class="rn-related__title">You May Also Like</h2>
    <div class="rn-related__grid">
      {%- assign count = 0 -%}
      {%- for p in collections.all.products -%}
        {%- if p.id != product.id and count < 4 -%}
          <a class="rn-related__card" href="{{ p.url }}">
            <div class="rn-related__card-img">
              {%- if p.featured_image -%}
                <img
                  src="{{ p.featured_image | image_url: width: 500 }}"
                  alt="{{ p.featured_image.alt | escape | default: p.title }}"
                  loading="lazy"
                >
              {%- endif -%}
            </div>
            <div class="rn-related__card-name">{{ p.title }}</div>
            <div class="rn-related__card-price">{{ p.price_min | money }}</div>
          </a>
          {%- assign count = count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
  {%- endif -%}

</div>

<!-- Toast -->
<div class="rn-toast" id="rn-toast">Added to cart!</div>




<script>
  window.__rnVariants__ = {{ product.variants | json }};

  // ============================================================
  // Rang Nisa Product Page - Global JS (must be in <script> tag)
  // ============================================================

  // Gallery: switch main image when thumbnail is clicked
  function rnSwitchImage(index, sectionId) {
    var featured = document.getElementById('rn-featured-img-' + sectionId);
    var thumbs = document.querySelectorAll('#rn-thumbs-' + sectionId + ' .rn-gallery__thumb');
    if (!featured || !thumbs[index]) return;

    // Get the full-res URL stored as data attribute (set in Liquid)
    var newSrc = thumbs[index].getAttribute('data-full');
    if (!newSrc) return;

    // CRITICAL: clear srcset and sizes so browser uses our src
    // (if srcset is present, browser ignores src changes)
    featured.removeAttribute('srcset');
    featured.removeAttribute('sizes');

    // Set the new image src directly
    featured.src = newSrc;
    featured.style.opacity = '1';

    // Update active thumbnail border
    thumbs.forEach(function(t) { t.classList.remove('active'); });
    thumbs[index].classList.add('active');
  }

  // Option selector for button-based options (size, colour)
  function rnSelectOption(btn, sectionId) {
    var optIdx = btn.getAttribute('data-option-index');
    var value = btn.getAttribute('data-value');

    // Deselect all siblings in same group
    var parent = btn.parentElement;
    parent.querySelectorAll('button').forEach(function(b) {
      b.classList.remove('selected');
    });
    btn.classList.add('selected');

    // Update the label next to option name
    var labelSpan = document.getElementById('rn-selected-' + sectionId + '-' + optIdx);
    if (labelSpan) labelSpan.textContent = value;

    // Update hidden variant input
    rnUpdateVariant(sectionId);
  }

  // For select dropdowns
  function rnSelectOptionFromSelect(sel, sectionId) {
    var optIdx = sel.getAttribute('data-option-index');
    var labelSpan = document.getElementById('rn-selected-' + sectionId + '-' + optIdx);
    if (labelSpan) labelSpan.textContent = sel.value;
    rnUpdateVariant(sectionId);
  }

  // Collect current selections and find matching variant
  function rnUpdateVariant(sectionId) {
    var variants = window.__rnVariants__;
    if (!variants || !variants.length) return;

    // Gather currently selected option values by index
    var selectedOpts = {};

    // From button groups (size, colour)
    document.querySelectorAll('.rn-product__size-btn.selected, .rn-product__color-text-btn.selected').forEach(function(btn) {
      var idx = parseInt(btn.getAttribute('data-option-index'));
      selectedOpts[idx] = btn.getAttribute('data-value');
    });

    // From select dropdowns
    document.querySelectorAll('.rn-product__option-select').forEach(function(sel) {
      var idx = parseInt(sel.getAttribute('data-option-index'));
      selectedOpts[idx] = sel.value;
    });

    // Find the variant that matches all selected options
    var match = null;
    for (var i = 0; i < variants.length; i++) {
      var v = variants[i];
      var opts = [v.option1, v.option2, v.option3];
      var isMatch = true;
      for (var j = 0; j < Object.keys(selectedOpts).length; j++) {
        if (selectedOpts[j] !== undefined && opts[j] !== selectedOpts[j]) {
          isMatch = false;
          break;
        }
      }
      if (isMatch) { match = v; break; }
    }

    if (!match) return;

    // Update hidden variant ID input
    var varInput = document.getElementById('rn-variant-id-' + sectionId);
    if (varInput) varInput.value = match.id;

    // Update ATC button state
    var atcBtn = document.getElementById('rn-atc-' + sectionId);
    if (atcBtn) {
      atcBtn.disabled = !match.available;
      atcBtn.textContent = match.available ? 'Add to Cart' : 'Sold Out';
    }

    // Update displayed price
    var priceRow = document.getElementById('rn-price-' + sectionId);
    if (priceRow && match.price !== undefined) {
      var priceFormatted = 'Rs.' + (match.price / 100).toFixed(2);
      if (match.compare_at_price && match.compare_at_price > match.price) {
        var cmpFormatted = 'Rs.' + (match.compare_at_price / 100).toFixed(2);
        priceRow.innerHTML = '<span class="rn-product__price rn-product__price--sale">' + priceFormatted + '</span><span class="rn-product__price--compare">' + cmpFormatted + '</span><span class="rn-product__badge">Sale</span>';
      } else {
        priceRow.innerHTML = '<span class="rn-product__price">' + priceFormatted + '</span>';
      }
    }

    // If variant has a specific image, show it
    if (match.featured_image && match.featured_image.position) {
      var imgIndex = match.featured_image.position - 1; // 1-based → 0-based
      rnSwitchImage(imgIndex, sectionId);
    }
  }

  // Quantity control
  function rnQty(delta, sectionId) {
    var input = document.getElementById('rn-qty-' + sectionId);
    if (!input) return;
    var val = Math.max(1, parseInt(input.value || 1) + delta);
    input.value = val;
  }

  // Accordion toggle
  function rnToggleAccordion(btn) {
    var item = btn.closest('.rn-accordion__item');
    if (item) item.classList.toggle('open');
  }

  // Wishlist button
  function rnWishlist(btn) {
    btn.innerHTML = '<span>\u2665</span> Wishlisted';
    btn.style.color = '#c0392b';
    btn.style.borderColor = '#c0392b';
  }

  // Share button
  function rnShare() {
    if (navigator.share) {
      navigator.share({ title: document.title, url: window.location.href });
    } else if (navigator.clipboard) {
      navigator.clipboard.writeText(window.location.href);
      rnShowToast('Link copied!');
    }
  }

  // Toast notification
  function rnShowToast(msg) {
    var toast = document.getElementById('rn-toast');
    if (!toast) return;
    toast.textContent = msg || 'Added to cart!';
    toast.classList.add('visible');
    setTimeout(function() { toast.classList.remove('visible'); }, 2500);
  }

  // ATC form: show toast on submit
  document.addEventListener('DOMContentLoaded', function() {
    var forms = document.querySelectorAll('[data-type="add-to-cart-form"]');
    forms.forEach(function(form) {
      form.addEventListener('submit', function() {
        var btn = form.querySelector('[name="add"]');
        if (btn && !btn.disabled) {
          setTimeout(function() { rnShowToast('Added to cart! \u2714'); }, 800);
        }
      });
    });
  });
</script>

