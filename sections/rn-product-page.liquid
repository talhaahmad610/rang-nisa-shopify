        </div>

        <div class="rn-accordion__item">
          <button class="rn-accordion__trigger" onclick="rnToggleAccordion(this)" type="button">
            <span class="rn-accordion__title">Shipping & Returns</span>
            <span class="rn-accordion__icon">+</span>
          </button>
          <div class="rn-accordion__body">
            <ul>
              <li>Free delivery on orders above Rs. 3,000 within Pakistan</li>
              <li>Standard delivery: 3–5 business days</li>
