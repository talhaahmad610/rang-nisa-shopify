{%- assign vol02 = section.settings.product -%}
{%- if vol02 != blank -%}

{%- comment %} Determine starting variant based on setting {%- endcomment %}
{%- assign default_color = section.settings.default_color | downcase | strip -%}
{%- assign active_variant = vol02.variants.first -%}
{%- assign active_image = vol02.featured_image -%}
{%- if default_color != blank -%}
  {%- for variant in vol02.variants -%}
    {%- assign variant_option = variant.option1 | downcase | strip -%}
    {%- unless variant_option contains default_color -%}
      {%- assign variant_option = variant.option2 | downcase | strip -%}
    {%- endunless -%}
    {%- if variant_option contains default_color and active_variant == vol02.variants.first -%}
      {%- assign active_variant = variant -%}
      {%- if variant.featured_image != blank -%}
        {%- assign active_image = variant.featured_image -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- assign on_sale = false -%}
{%- if active_variant.compare_at_price > active_variant.price -%}
  {%- assign on_sale = true -%}
{%- endif -%}
{%- assign savings = active_variant.compare_at_price | minus: active_variant.price -%}

{%- comment %} Collect images: active image first, then others {%- endcomment %}
{%- assign all_images = vol02.images -%}

<style>
  .rnfp2 {
    background: #f9f5f0;
    padding: 60px 0;
    font-family: inherit;
  }
  .rnfp2__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    gap: 48px;
    align-items: flex-start;
  }

  /* ---- LEFT: image gallery ---- */
  .rnfp2__gallery {
    display: flex;
    gap: 12px;
    flex-shrink: 0;
  }
  .rnfp2__thumbs {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 80px;
    flex-shrink: 0;
  }
  .rnfp2__thumb {
    width: 76px;
    height: 100px;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s;
    background: #eee;
  }
  .rnfp2__thumb.active,
  .rnfp2__thumb:hover {
    border-color: #111;
  }
  .rnfp2__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }
  .rnfp2__main-img {
    flex: 1;
    max-width: 520px;
    overflow: hidden;
    background: #f5f0eb;
    position: relative;
  }
  .rnfp2__main-img img {
    width: 100%;
    display: block;
    object-fit: cover;
    object-position: top center;
    aspect-ratio: 3/4;
    transition: opacity 0.3s;
  }
  .rnfp2__main-img img.fade { opacity: 0; }

  /* ---- RIGHT: product details ---- */
  .rnfp2__details {
    flex: 1;
    padding-top: 12px;
  }
  .rnfp2__title {
    font-size: 1.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #111;
    margin: 0 0 20px;
    line-height: 1.2;
  }
  .rnfp2__price-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 4px;
  }
  .rnfp2__price-compare {
    font-size: 1.05rem;
    color: #999;
    text-decoration: line-through;
  }
  .rnfp2__price-sale {
    font-size: 1.05rem;
    font-weight: 600;
    color: #111;
  }
  .rnfp2__price-save {
    font-size: 1rem;
    color: #c0392b;
    font-weight: 600;
  }
  .rnfp2__shipping {
    font-size: 0.85rem;
    color: #555;
    margin: 6px 0 20px;
  }
  .rnfp2__shipping a {
    color: #555;
    text-decoration: underline;
  }
  .rnfp2__desc {
    font-size: 0.95rem;
    color: #444;
    line-height: 1.7;
    margin-bottom: 24px;
  }
  .rnfp2__desc p { margin: 0 0 14px; }
  .rnfp2__desc p:last-child { margin-bottom: 0; }
  .rnfp2__sizes-label {
    font-size: 0.9rem;
    font-weight: 700;
    color: #111;
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .rnfp2__sizes {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .rnfp2__size-btn {
    padding: 8px 18px;
    border: 1.5px solid #ccc;
    background: #fff;
    font-size: 0.85rem;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    letter-spacing: 0.05em;
    color: #111;
  }
  .rnfp2__size-btn:hover,
  .rnfp2__size-btn.active {
    border-color: #111;
    background: #111;
    color: #fff;
  }
  .rnfp2__cta {
    margin-top: 28px;
  }
  .rnfp2__cta a {
    display: inline-block;
    padding: 14px 36px;
    background: #111;
    color: #fff;
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: background 0.2s;
  }
  .rnfp2__cta a:hover { background: #333; }

  @media (max-width: 768px) {
    .rnfp2__inner {
      flex-direction: column;
      gap: 24px;
    }
    .rnfp2__gallery {
      width: 100%;
    }
    .rnfp2__main-img {
      max-width: 100%;
    }
  }
</style>

<section class="rnfp2" id="vol02-fp-{{ section.id }}">
  <div class="rnfp2__inner">

    {%- comment %} LEFT: Gallery {%- endcomment %}
    <div class="rnfp2__gallery">
      <div class="rnfp2__thumbs">
        {%- for image in all_images limit: 6 -%}
          <div class="rnfp2__thumb{% if image == active_image %} active{% endif %}" data-src="{{ image | image_url: width: 800 }}">
            <img src="{{ image | image_url: width: 120 }}" alt="{{ image.alt | default: vol02.title | escape }}" loading="lazy">
          </div>
        {%- endfor -%}
      </div>
      <div class="rnfp2__main-img">
        <img id="rnfp2-main-{{ section.id }}" src="{{ active_image | image_url: width: 800 }}" alt="{{ vol02.title | escape }}" loading="eager">
      </div>
    </div>

    {%- comment %} RIGHT: Product Details {%- endcomment %}
    <div class="rnfp2__details">
      <h2 class="rnfp2__title">{{ vol02.title }}</h2>

      <div class="rnfp2__price-row" id="rnfp2-price-{{ section.id }}">
        {%- if on_sale -%}
          <span class="rnfp2__price-compare">{{ active_variant.compare_at_price | money }}</span>
          <span class="rnfp2__price-sale">{{ active_variant.price | money }}</span>
          <span class="rnfp2__price-save">Save {{ savings | money }}</span>
        {%- else -%}
          <span class="rnfp2__price-sale">{{ active_variant.price | money }}</span>
        {%- endif -%}
      </div>

      <p class="rnfp2__shipping">Shipping calculated at checkout.</p>

      {%- if vol02.description != blank -%}
        <div class="rnfp2__desc">{{ vol02.description }}</div>
      {%- endif -%}

      {%- comment %} Size options — show unique values of the size option {%- endcomment %}
      {%- assign size_option_index = nil -%}
      {%- for option in vol02.options -%}
        {%- assign opt_lower = option | downcase -%}
        {%- if opt_lower == 'size' -%}
          {%- assign size_option_index = forloop.index0 -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if size_option_index != nil -%}
        {%- assign shown_sizes = '' -%}
        <p class="rnfp2__sizes-label">Available Sizes:</p>
        <div class="rnfp2__sizes" id="rnfp2-sizes-{{ section.id }}">
          {%- for variant in vol02.variants -%}
            {%- assign sz = variant.options[size_option_index] -%}
            {%- unless shown_sizes contains sz -%}
              {%- assign shown_sizes = shown_sizes | append: sz | append: ',' -%}
              <button class="rnfp2__size-btn{% if variant == active_variant %} active{% endif %}" data-variant-id="{{ variant.id }}" data-size="{{ sz }}">{{ sz }}</button>
            {%- endunless -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="rnfp2__cta">
        <a href="{{ vol02.url }}">Shop Now</a>
      </div>
    </div>

  </div>
</section>

<script>
(function() {
  var sectionId = '{{ section.id }}';
  var mainImg = document.getElementById('rnfp2-main-' + sectionId);
  var thumbs = document.querySelectorAll('#vol02-fp-' + sectionId + ' .rnfp2__thumb');
  var sizeBtns = document.querySelectorAll('#rnfp2-sizes-' + sectionId + ' .rnfp2__size-btn');

  // Thumbnail switcher
  thumbs.forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      thumbs.forEach(function(t) { t.classList.remove('active'); });
      thumb.classList.add('active');
      mainImg.classList.add('fade');
      setTimeout(function() {
        mainImg.src = thumb.getAttribute('data-src');
        mainImg.onload = function() { mainImg.classList.remove('fade'); };
      }, 150);
    });
  });

  // Size button selector
  sizeBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      sizeBtns.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
    });
  });
})();
</script>

{%- endif -%}

{% schema %}
{
  "name": "Vol 02 Featured Product",
  "tag": "section",
  "class": "section-vol02-fp",
  "settings": [
    { "type": "product", "id": "product", "label": "Featured Product" },
    {
      "type": "text",
      "id": "default_color",
      "label": "Default Color / Variant to show first",
      "info": "Type the color name (e.g. Turquoise, Beige, Pink). Leave blank to show the first variant."
    },
    { "type": "text", "id": "section_label", "label": "Section Label", "default": "Featured Product" }
  ],
  "presets": [
    { "name": "Vol 02 Featured Product" }
  ]
}
{% endschema %}