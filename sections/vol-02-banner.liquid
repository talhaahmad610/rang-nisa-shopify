{%- assign vol02 = all_products['vol-02-embroidery-cotton-suit'] -%}
{%- assign display_image = section.settings.image | default: vol02.featured_image -%}
<style>
  .rn-vol02 { background-color: #1a1a1a; padding: 0; overflow: hidden; }
  .rn-vol02__inner { display: flex; align-items: stretch; min-height: 520px; }
  .rn-vol02__image-side { flex: 1; position: relative; overflow: hidden; }
  .rn-vol02__image-side img { width: 100%; height: 100%; object-fit: cover; object-position: top center; display: block; }
  .rn-vol02__content-side { flex: 1; background-color: #1a1a1a; display: flex; flex-direction: column; justify-content: center; padding: 48px 52px; }
  .rn-vol02__eyebrow { font-size: 0.8rem; letter-spacing: 0.25em; text-transform: uppercase; color: #c9a96e; margin-bottom: 12px; }
  .rn-vol02__vol-label { font-size: 4.5rem; font-weight: 700; color: #ffffff; line-height: 1; margin-bottom: 4px; }
  .rn-vol02__vol-sub { font-size: 1.1rem; color: #c9a96e; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }
  .rn-vol02__divider { width: 48px; height: 2px; background-color: #c9a96e; margin-bottom: 20px; }
  .rn-vol02__title { font-size: 1.4rem; color: #ffffff; font-weight: 500; margin-bottom: 12px; }
  .rn-vol02__description { font-size: 1rem; color: #b0a898; line-height: 1.7; margin-bottom: 32px; }
  .rn-vol02__btn { display: inline-block; padding: 14px 36px; background-color: #c9a96e; color: #1a1a1a; text-decoration: none; font-size: 0.85rem; letter-spacing: 0.15em; text-transform: uppercase; font-weight: 600; transition: background-color 0.3s ease; }
  .rn-vol02__btn:hover { background-color: transparent; color: #c9a96e; border: 1px solid #c9a96e; }
  @media (max-width: 768px) {
    .rn-vol02__inner { flex-direction: column; }
    .rn-vol02__image-side { min-height: 320px; }
    .rn-vol02__content-side { padding: 36px 24px; }
    .rn-vol02__vol-label { font-size: 3rem; }
  }
</style>

<div class="rn-vol02">
  <div class="rn-vol02__inner">
    <div class="rn-vol02__image-side">
      {%- if display_image != blank -%}
        <img
          src="{{ display_image | image_url: width: 800 }}"
          alt="{{ display_image.alt | escape }}"
          loading="lazy"
          width="{{ display_image.width }}"
          height="{{ display_image.height }}"
        >
      {%- endif -%}
    </div>
    <div class="rn-vol02__content-side">
      <p class="rn-vol02__eyebrow">New Collection</p>
      <div class="rn-vol02__vol-label">VOL</div>
      <div class="rn-vol02__vol-sub">02</div>
      <div class="rn-vol02__divider"></div>
      {%- if vol02 != blank -%}
        <h2 class="rn-vol02__title">{{ vol02.title }}</h2>
      {%- endif -%}
      <p class="rn-vol02__description">{{ section.settings.description | default: 'Discover our latest collection — crafted for elegance and designed for every occasion.' }}</p>
      <a href="{{ section.settings.button_link | default: '/products/vol-02-embroidery-cotton-suit' }}" class="rn-vol02__btn">
        {{ section.settings.button_label | default: 'Shop Vol 02' }}
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Vol 02 Banner",
  "tag": "section",
  "class": "section-vol02",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Collection Image (optional - auto-loads from Vol 02 product)" },
    { "type": "text", "id": "button_label", "label": "Button Label", "default": "Shop Vol 02" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Discover our latest collection — crafted for elegance and designed for every occasion." }
  ],
  "presets": [
    { "name": "Vol 02 Banner" }
  ]
}
{% endschema %}