{% liquid
  assign section_collections = collections
    assign max_items = 20
      assign page_title = section.settings.title | default: 'Collections'
      %}
      
      <style>
        .rn-collection-list-section {
            max-width: 1400px;
                margin: 0 auto;
                    padding: 60px 20px;
                      }
                        .rn-collection-list-section h1 {
                            text-align: center;
                                font-size: 2.2rem;
                                    font-weight: 400;
                                        letter-spacing: 0.15em;
                                            text-transform: uppercase;
                                                margin-bottom: 50px;
                                                    color: #1a1a1a;
                                                      }
                                                        .rn-collections-grid {
                                                            display: grid;
                                                                grid-template-columns: repeat(3, 1fr);
                                                                    gap: 16px;
                                                                      }
                                                                        @media (max-width: 900px) {
                                                                            .rn-collections-grid {
                                                                                  grid-template-columns: repeat(2, 1fr);
                                                                                        gap: 12px;
                                                                                            }
                                                                                              }
                                                                                                @media (max-width: 480px) {
                                                                                                    .rn-collections-grid {
                                                                                                          grid-template-columns: repeat(2, 1fr);
                                                                                                                gap: 8px;
                                                                                                                    }
                                                                                                                        .rn-collection-list-section {
                                                                                                                              padding: 30px 12px;
                                                                                                                                  }
                                                                                                                                      .rn-collection-list-section h1 {
                                                                                                                                            font-size: 1.5rem;
                                                                                                                                                  margin-bottom: 30px;
                                                                                                                                                      }
                                                                                                                                                        }
                                                                                                                                                          .rn-collection-card {
                                                                                                                                                              position: relative;
                                                                                                                                                                  display: block;
                                                                                                                                                                      overflow: hidden;
                                                                                                                                                                          text-decoration: none;
                                                                                                                                                                              background: #f5f5f5;
                                                                                                                                                                                  aspect-ratio: 3 / 4;
                                                                                                                                                                                    }
                                                                                                                                                                                      .rn-collection-card:hover .rn-collection-card__img {
                                                                                                                                                                                          transform: scale(1.04);
                                                                                                                                                                                            }
                                                                                                                                                                                              .rn-collection-card__img {
                                                                                                                                                                                                  width: 100%;
                                                                                                                                                                                                      height: 100%;
                                                                                                                                                                                                          object-fit: cover;
                                                                                                                                                                                                              display: block;
                                                                                                                                                                                                                  transition: transform 0.5s ease;
                                                                                                                                                                                                                    }
                                                                                                                                                                                                                      .rn-collection-card__overlay {
                                                                                                                                                                                                                          position: absolute;
                                                                                                                                                                                                                              bottom: 0;
                                                                                                                                                                                                                                  left: 0;
                                                                                                                                                                                                                                      right: 0;
                                                                                                                                                                                                                                          padding: 20px 16px 18px;
                                                                                                                                                                                                                                              background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0) 100%);
                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                  .rn-collection-card__title {
                                                                                                                                                                                                                                                      color: #fff;
                                                                                                                                                                                                                                                          font-size: 1rem;
                                                                                                                                                                                                                                                              font-weight: 500;
                                                                                                                                                                                                                                                                  letter-spacing: 0.08em;
                                                                                                                                                                                                                                                                      text-transform: uppercase;
                                                                                                                                                                                                                                                                          margin: 0 0 4px;
                                                                                                                                                                                                                                                                              text-align: left;
                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                  .rn-collection-card__count {
                                                                                                                                                                                                                                                                                      color: rgba(255,255,255,0.8);
                                                                                                                                                                                                                                                                                          font-size: 0.8rem;
                                                                                                                                                                                                                                                                                              letter-spacing: 0.04em;
                                                                                                                                                                                                                                                                                                  margin: 0;
                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                                      .rn-collection-card__placeholder {
                                                                                                                                                                                                                                                                                                          width: 100%;
                                                                                                                                                                                                                                                                                                              height: 100%;
                                                                                                                                                                                                                                                                                                                  background: linear-gradient(135deg, #e8e0d8 0%, #d4c8bc 100%);
                                                                                                                                                                                                                                                                                                                      display: flex;
                                                                                                                                                                                                                                                                                                                          align-items: center;
                                                                                                                                                                                                                                                                                                                              justify-content: center;
                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                  .rn-collection-card__placeholder svg {
                                                                                                                                                                                                                                                                                                                                      width: 60px;
                                                                                                                                                                                                                                                                                                                                          height: 60px;
                                                                                                                                                                                                                                                                                                                                              fill: rgba(0,0,0,0.15);
                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                </style>
                                                                                                                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                                                                                                                <div class="rn-collection-list-section">
                                                                                                                                                                                                                                                                                                                                                  <h1>{{ page_title }}</h1>
                                                                                                                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                                                                                                                    <div class="rn-collections-grid">
                                                                                                                                                                                                                                                                                                                                                        {% for collection in section_collections limit: max_items %}
                                                                                                                                                                                                                                                                                                                                                              {% unless collection.handle == 'frontpage' %}
                                                                                                                                                                                                                                                                                                                                                                      <a href="{{ collection.url }}" class="rn-collection-card">
                                                                                                                                                                                                                                                                                                                                                                                {% if collection.image %}
                                                                                                                                                                                                                                                                                                                                                                                            <img
                                                                                                                                                                                                                                                                                                                                                                                                          class="rn-collection-card__img"
                                                                                                                                                                                                                                                                                                                                                                                                                        src="{{ collection.image | image_url: width: 600 }}"
                                                                                                                                                                                                                                                                                                                                                                                                                                      alt="{{ collection.title | escape }}"
                                                                                                                                                                                                                                                                                                                                                                                                                                                    loading="lazy"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                  width="600"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                height="800"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            >
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      {% elsif collection.products.first.featured_image %}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <img
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                class="rn-collection-card__img"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              src="{{ collection.products.first.featured_image | image_url: width: 600 }}"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            alt="{{ collection.title | escape }}"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          loading="lazy"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        width="600"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      height="800"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  >
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            {% else %}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <div class="rn-collection-card__placeholder">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            {% endif %}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      <div class="rn-collection-card__overlay">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <p class="rn-collection-card__title">{{ collection.title }}</p>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <p class="rn-collection-card__count">{{ collection.products_count }} items</p>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                </a>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      {% endunless %}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          {% endfor %}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            {% schema %}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "name": "Collection List",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "tag": "section",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  "class": "section",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "settings": [
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "type": "text",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "id": "title",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          "label": "Heading",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "default": "Collections"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "type": "color_scheme",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "id": "color_scheme",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          "label": "t:settings.color_scheme",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "default": "scheme-1"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "type": "header",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "content": "t:content.spacing"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  "type": "range",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "id": "padding_top",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "min": 0,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "max": 100,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          "step": 4,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "unit": "px",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "label": "t:settings.padding_top",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "default": 36
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          "type": "range",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "id": "padding_bottom",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "min": 0,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "max": 100,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  "step": 4,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "unit": "px",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "label": "t:settings.padding_bottom",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "default": 36
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          ]
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          {% endschema %}}