<section
  class="page-header color-{{ section.settings.color_scheme }} page-header--{{ section.settings.text_alignment }}"
  style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-header__inner page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="page-header__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="page-header__heading">{{ section.settings.heading | escape }}</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <div class="page-header__subheading rte">{{ section.settings.subheading }}</div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .page-header {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
  }

  .page-header__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 760px;
  }

  .page-header--center .page-header__inner {
    align-items: center;
    text-align: center;
    margin-inline: auto;
  }

  .page-header__eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-gray-500);
    margin: 0;
  }

  .page-header__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 7vw, 3.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0;
    color: var(--color-black);
  }

  .page-header__subheading {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gray-600);
    margin: 0;
    max-width: 60ch;
  }

  .page-header__subheading p {
    margin: 0;
  }

  @media (min-width: 750px) {
    .page-header__subheading {
      font-size: 1.0625rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.page_header.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:settings.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Page title"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "t:settings.subheading",
      "default": "<p>Add a short introduction for this page.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "t:settings.alignment",
      "options": [
        { "value": "left", "label": "t:options.left" },
        { "value": "center", "label": "t:options.center" }
      ],
      "default": "center"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:settings.padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:settings.padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "t:sections.page_header.name"
    }
  ]
}
{% endschema %}
