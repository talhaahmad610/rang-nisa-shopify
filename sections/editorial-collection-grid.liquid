{%- liquid
  assign heading = section.settings.heading
  assign show_heading = section.settings.show_heading
  assign layout = section.settings.layout
  assign is_slider = false
  if layout == 'slider'
    assign is_slider = true
  endif
-%}

<section
  class="editorial-collection-grid color-{{ section.settings.color_scheme }}"
  aria-label="{{ heading | escape }}"
>
  {%- if show_heading and heading != blank -%}
    <header class="editorial-collection-grid__header">
      <h2 class="editorial-collection-grid__heading">{{ heading | escape }}</h2>
    </header>
  {%- endif -%}

  <div class="editorial-collection-grid__track-wrapper">
    <div
      class="editorial-collection-grid__track editorial-collection-grid__track--{{ layout }}{%- if layout == 'grid' and section.blocks.size > 3 %} editorial-collection-grid__track--grid-many{%- endif -%}"
      role="list"
      {%- if is_slider -%}
        id="CategorySlider-{{ section.id }}"
      {%- endif -%}
    >
      {%- for block in section.blocks -%}
        {%- liquid
          assign collection = block.settings.collection
          assign custom_image = block.settings.image
          assign custom_label = block.settings.label

          if custom_image
            assign image = custom_image
          elsif collection.image
            assign image = collection.image
          elsif collection.products.first.featured_image
            assign image = collection.products.first.featured_image
          else
            assign image = nil
          endif

          if custom_label != blank
            assign title = custom_label
          elsif collection != blank
            assign title = collection.title
          else
            assign title = 'sections.editorial_collection_grid.placeholder_title' | t
          endif

          if collection != blank
            assign product_count = collection.products_count
            assign url = collection.url
          else
            assign product_count = 0
            assign url = '#'
          endif
        -%}

        <article
          class="editorial-collection-grid__item{%- unless is_slider %} editorial-collection-grid__item--{{ forloop.index }}{%- endunless -%}"
          role="listitem"
          {{ block.shopify_attributes }}
        >
          <a href="{{ url }}" class="editorial-collection-grid__link" aria-label="{{ title | escape }}">
            <div class="editorial-collection-grid__media">
              {%- if image -%}
                {{ image | image_url: width: 1200 | image_tag:
                  loading: 'lazy',
                  class: 'editorial-collection-grid__image',
                  widths: '375, 550, 750, 1000, 1200',
                  sizes: '(max-width: 749px) 72vw, 30vw'
                }}
              {%- else -%}
                {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'editorial-collection-grid__placeholder' }}
              {%- endif -%}
            </div>

            <div class="editorial-collection-grid__overlay">
              <h3 class="editorial-collection-grid__title">{{ title | escape }}</h3>
              <span class="editorial-collection-grid__count">
                {{ 'sections.editorial_collection_grid.products_count' | t: count: product_count }}
              </span>
            </div>
          </a>
        </article>
      {%- endfor -%}
    </div>

    {%- if is_slider and section.blocks.size > 1 -%}
      <button
        class="editorial-collection-grid__arrow editorial-collection-grid__arrow--prev"
        aria-label="{{ 'sections.editorial_collection_grid.previous' | t }}"
        data-slider-id="CategorySlider-{{ section.id }}"
        data-direction="prev"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button
        class="editorial-collection-grid__arrow editorial-collection-grid__arrow--next"
        aria-label="{{ 'sections.editorial_collection_grid.next' | t }}"
        data-slider-id="CategorySlider-{{ section.id }}"
        data-direction="next"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .editorial-collection-grid {
    padding: 2rem 0;
    overflow: hidden;
  }

  .editorial-collection-grid__header {
    padding: 0 1rem 1.5rem;
  }

  .editorial-collection-grid__heading {
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
  }

  .editorial-collection-grid__track-wrapper {
    position: relative;
  }

  /* ---- SLIDER MODE ---- */
  .editorial-collection-grid__track--slider {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: 1px;
  }

  .editorial-collection-grid__track--slider::-webkit-scrollbar {
    display: none;
  }

  .editorial-collection-grid__track--slider .editorial-collection-grid__item {
    flex: 0 0 auto;
    width: 72vw;
    scroll-snap-align: start;
  }

  @media screen and (min-width: 750px) {
    .editorial-collection-grid__track--slider .editorial-collection-grid__item {
      width: 30%;
    }
  }

  .editorial-collection-grid__track--slider .editorial-collection-grid__link {
    min-height: 360px;
  }

  @media screen and (min-width: 750px) {
    .editorial-collection-grid__track--slider .editorial-collection-grid__link {
      min-height: 480px;
    }
  }

  /* Arrow buttons */
  .editorial-collection-grid__arrow {
    display: none;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 40px;
    height: 40px;
    background: #fff;
    border: 1px solid #000;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    color: #000;
    padding: 0;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .editorial-collection-grid__arrow:hover {
    background: #000;
    color: #fff;
  }

  @media screen and (min-width: 750px) {
    .editorial-collection-grid__arrow {
      display: flex;
    }
  }

  .editorial-collection-grid__arrow--prev {
    left: 0.75rem;
  }

  .editorial-collection-grid__arrow--next {
    right: 0.75rem;
  }

  /* ---- GRID MODE ---- */
  .editorial-collection-grid__track--grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
  }

  .editorial-collection-grid__track--grid .editorial-collection-grid__item--1 {
    grid-column: 1;
    grid-row: 1 / 3;
  }

  .editorial-collection-grid__track--grid .editorial-collection-grid__item--2 {
    grid-column: 2;
    grid-row: 1;
  }

  .editorial-collection-grid__track--grid .editorial-collection-grid__item--3 {
    grid-column: 2;
    grid-row: 2;
  }

  .editorial-collection-grid__track--grid .editorial-collection-grid__item--1 .editorial-collection-grid__link {
    min-height: 500px;
  }

  .editorial-collection-grid__track--grid .editorial-collection-grid__item--2 .editorial-collection-grid__link,
  .editorial-collection-grid__track--grid .editorial-collection-grid__item--3 .editorial-collection-grid__link {
    min-height: 249px;
  }

  /* Grid with more than 3 items — uniform responsive grid */
  .editorial-collection-grid__track--grid-many {
    grid-template-columns: repeat(2, 1fr) !important;
  }

  .editorial-collection-grid__track--grid-many .editorial-collection-grid__item {
    grid-column: auto !important;
    grid-row: auto !important;
  }

  .editorial-collection-grid__track--grid-many .editorial-collection-grid__link {
    min-height: 300px;
  }

  @media screen and (min-width: 750px) {
    .editorial-collection-grid__track--grid-many {
      grid-template-columns: repeat(3, 1fr) !important;
    }
  }

  /* Mobile grid: single column */
  @media screen and (max-width: 749px) {
    .editorial-collection-grid__track--grid {
      grid-template-columns: 1fr;
    }

    .editorial-collection-grid__track--grid .editorial-collection-grid__item--1,
    .editorial-collection-grid__track--grid .editorial-collection-grid__item--2,
    .editorial-collection-grid__track--grid .editorial-collection-grid__item--3 {
      grid-column: 1;
      grid-row: auto;
    }

    .editorial-collection-grid__track--grid .editorial-collection-grid__item--1 .editorial-collection-grid__link,
    .editorial-collection-grid__track--grid .editorial-collection-grid__item--2 .editorial-collection-grid__link,
    .editorial-collection-grid__track--grid .editorial-collection-grid__item--3 .editorial-collection-grid__link {
      min-height: 300px;
    }
  }

  /* ---- SHARED CARD STYLES ---- */
  .editorial-collection-grid__link {
    display: block;
    position: relative;
    overflow: hidden;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .editorial-collection-grid__media {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .editorial-collection-grid__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .editorial-collection-grid__link:hover .editorial-collection-grid__image {
    transform: scale(1.03);
  }

  .editorial-collection-grid__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background-color: #f0f0f0;
  }

  .editorial-collection-grid__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: 1.25rem;
    z-index: 1;
  }

  .editorial-collection-grid__title {
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    margin: 0 0 0.25rem;
    color: #fff;
  }

  .editorial-collection-grid__count {
    font-size: 0.625rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
  }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('.editorial-collection-grid__arrow').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var sliderId = btn.getAttribute('data-slider-id');
      var direction = btn.getAttribute('data-direction');
      var slider = document.getElementById(sliderId);
      if (!slider) return;
      var firstItem = slider.querySelector('.editorial-collection-grid__item');
      if (!firstItem) return;
      var itemWidth = firstItem.offsetWidth + 1;
      slider.scrollBy({ left: direction === 'next' ? itemWidth : -itemWidth, behavior: 'smooth' });
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.editorial_collection_grid.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Shop by category"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "t:sections.editorial_collection_grid.show_heading",
      "default": true
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.editorial_collection_grid.layout",
      "options": [
        { "value": "slider", "label": "t:options.slider" },
        { "value": "grid", "label": "t:options.grid_layout" }
      ],
      "default": "slider"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "t:names.collection",
      "limit": 12,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:settings.collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:settings.image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "t:settings.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.editorial_collection_grid.name",
      "settings": {
        "heading": "Shop by category",
        "layout": "slider"
      },
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
