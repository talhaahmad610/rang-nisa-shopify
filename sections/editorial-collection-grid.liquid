{% liquid
  assign heading = section.settings.heading
  assign show_heading = section.settings.show_heading
%}

<section
  class="editorial-collection-grid color-{{ section.settings.color_scheme }}"
  aria-label="{{ heading | escape }}"
>
  {% if show_heading and heading != blank %}
    <header class="editorial-collection-grid__header">
      <h2 class="editorial-collection-grid__heading">{{ heading | escape }}</h2>
    </header>
  {% endif %}

  <div class="editorial-collection-grid__grid" role="list">
    {% for block in section.blocks %}
      {% liquid
        assign collection = block.settings.collection
        assign custom_image = block.settings.image
        assign custom_label = block.settings.label

        if custom_image
          assign image = custom_image
        elsif collection.image
          assign image = collection.image
        elsif collection.products.first.featured_image
          assign image = collection.products.first.featured_image
        else
          assign image = nil
        endif

        if custom_label != blank
          assign title = custom_label
        elsif collection != blank
          assign title = collection.title
        else
          assign title = 'sections.editorial_collection_grid.placeholder_title' | t
        endif

        if collection != blank
          assign product_count = collection.products_count
          assign url = collection.url
        else
          assign product_count = 0
          assign url = '#'
        endif
      %}

      <article
        class="editorial-collection-grid__item editorial-collection-grid__item--{{ forloop.index }}"
        role="listitem"
        {{ block.shopify_attributes }}
      >
        <a href="{{ url }}" class="editorial-collection-grid__link" aria-label="{{ title | escape }}">
          <div class="editorial-collection-grid__media">
            {% if image %}
              {{ image | image_url: width: 1200 | image_tag:
                loading: 'lazy',
                class: 'editorial-collection-grid__image',
                widths: '375, 550, 750, 1000, 1200',
                sizes: '(max-width: 749px) 100vw, (max-width: 1199px) 50vw, 50vw'
              }}
            {% else %}
              {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'editorial-collection-grid__placeholder' }}
            {% endif %}
          </div>

          <div class="editorial-collection-grid__overlay">
            <h3 class="editorial-collection-grid__title">{{ title | escape }}</h3>
            <span class="editorial-collection-grid__count">
              {{ 'sections.editorial_collection_grid.products_count' | t: count: product_count }}
            </span>
          </div>
        </a>
      </article>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .editorial-collection-grid {
    padding: 2rem 0;
  }

  .editorial-collection-grid__header {
    padding: 0 1rem 1.5rem;
  }

  .editorial-collection-grid__heading {
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
  }

  .editorial-collection-grid__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 1px;
  }

  .editorial-collection-grid__item--1 {
    grid-column: 1;
    grid-row: 1 / 3;
  }

  .editorial-collection-grid__item--2 {
    grid-column: 2;
    grid-row: 1;
  }

  .editorial-collection-grid__item--3 {
    grid-column: 2;
    grid-row: 2;
  }

  .editorial-collection-grid__link {
    display: block;
    position: relative;
    overflow: hidden;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .editorial-collection-grid__media {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .editorial-collection-grid__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .editorial-collection-grid__link:hover .editorial-collection-grid__image {
    transform: scale(1.03);
  }

  .editorial-collection-grid__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background-color: #f0f0f0;
  }

  .editorial-collection-grid__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: 1.25rem;
    z-index: 1;
  }

  .editorial-collection-grid__title {
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    margin: 0 0 0.25rem;
    color: #fff;
  }

  .editorial-collection-grid__count {
    font-size: 0.625rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
  }

  .editorial-collection-grid__item--1 .editorial-collection-grid__link {
    min-height: 500px;
  }

  .editorial-collection-grid__item--2 .editorial-collection-grid__link,
  .editorial-collection-grid__item--3 .editorial-collection-grid__link {
    min-height: 249px;
  }

  @media screen and (max-width: 749px) {
    .editorial-collection-grid__grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }

    .editorial-collection-grid__item--1 {
      grid-column: 1;
      grid-row: auto;
    }

    .editorial-collection-grid__item--2 {
      grid-column: 1;
      grid-row: auto;
    }

    .editorial-collection-grid__item--3 {
      grid-column: 1;
      grid-row: auto;
    }

    .editorial-collection-grid__item--1 .editorial-collection-grid__link,
    .editorial-collection-grid__item--2 .editorial-collection-grid__link,
    .editorial-collection-grid__item--3 .editorial-collection-grid__link {
      min-height: 300px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.editorial_collection_grid.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Shop by category"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "t:sections.editorial_collection_grid.show_heading",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "t:names.collection",
      "limit": 3,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:settings.collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:settings.image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "t:settings.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.editorial_collection_grid.name",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
