<section
  class="text-split color-{{ section.settings.color_scheme }}"
  style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="text-split__inner grid grid--split{% if section.settings.image_position == 'right' %} text-split__inner--reverse{% endif %}">
    <div class="text-split__image-col">
      {%- if section.settings.image -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            class: 'text-split__image',
            widths: '400,600,800,1200',
            sizes: '(min-width: 750px) 50vw, 100vw'
        }}
      {%- else -%}
        <div class="text-split__image-placeholder">
          {{ 'image' | placeholder_svg_tag: 'text-split__placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>

    <div class="text-split__content-col">
      <div class="text-split__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="text-split__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="text-split__description rte">{{ section.settings.description }}</div>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a
            href="{{ section.settings.button_link | default: '#' }}"
            class="btn btn--primary text-split__cta"
          >
            {{- section.settings.button_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .text-split {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
  }

  .text-split__inner {
    align-items: stretch;
  }

  .text-split__inner--reverse {
    direction: rtl;
  }

  .text-split__inner--reverse > * {
    direction: ltr;
  }

  .text-split__image-col {
    overflow: hidden;
    min-height: 400px;
  }

  .text-split__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .text-split__image-placeholder {
    width: 100%;
    height: 100%;
    min-height: 400px;
    background-color: var(--color-gray-100);
  }

  .text-split__placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .text-split__content-col {
    display: flex;
    align-items: center;
  }

  .text-split__content {
    padding: var(--space-8) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    max-width: 520px;
  }

  @media (min-width: 750px) {
    .text-split__content {
      padding: var(--space-10) var(--space-8);
    }
  }

  .text-split__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
    color: var(--color-black);
  }

  .text-split__description {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gray-600);
    margin: 0;
  }

  .text-split__description p {
    margin: 0;
  }

  .text-split__cta {
    align-self: flex-start;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.text_with_image_split.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:settings.image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:settings.image_position",
      "options": [
        { "value": "left", "label": "t:options.left" },
        { "value": "right", "label": "t:options.right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "t:sections.text_with_image_split.heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:settings.description",
      "default": "<p>t:sections.text_with_image_split.description</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:settings.label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:settings.link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:settings.padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:settings.padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "t:sections.text_with_image_split.name"
    }
  ]
}
{% endschema %}
