{%- liquid
  assign has_video = false
  assign has_external_video = false
  assign has_image = false

  if section.settings.video != blank
    assign has_video = true
  endif

  if section.settings.video_url != blank
    assign has_external_video = true
  endif

  if section.settings.image != blank
    assign has_image = true
  endif

  assign height_class = 'hero-video-banner--full-height'
  unless section.settings.full_height
    assign height_class = 'hero-video-banner--auto-height'
  endunless

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}

<section
  id="HeroVideoBanner-{{ section.id }}"
  class="hero-video-banner {{ height_class }} color-{{ section.settings.color_scheme }}"
  style="--overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}"
>
  <div class="hero-video-banner__media">
    {%- if has_video -%}
      {{
        section.settings.video
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          class: 'hero-video-banner__video'
      }}
    {%- elsif has_external_video -%}
      {%- if section.settings.video_url.type == 'youtube' -%}
        <iframe
          class="hero-video-banner__video hero-video-banner__video--external"
          src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ section.settings.video_url.id }}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1"
          allow="autoplay; encrypted-media"
          allowfullscreen
          loading="lazy"
          title="{{ 'sections.hero_video_banner.video' | t }}"
        ></iframe>
      {%- elsif section.settings.video_url.type == 'vimeo' -%}
        <iframe
          class="hero-video-banner__video hero-video-banner__video--external"
          src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay=1&muted=1&loop=1&background=1&playsinline=1"
          allow="autoplay; encrypted-media"
          allowfullscreen
          loading="lazy"
          title="{{ 'sections.hero_video_banner.video' | t }}"
        ></iframe>
      {%- endif -%}
    {%- elsif has_image -%}
      {{
        section.settings.image
        | image_url: width: 3840
        | image_tag:
          widths: '375, 750, 1100, 1500, 1920, 2560, 3840',
          sizes: '100vw',
          class: 'hero-video-banner__image',
          loading: 'lazy',
          fetchpriority: fetch_priority,
          alt: section.settings.image.alt
      }}
    {%- else -%}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero-video-banner__placeholder' }}
    {%- endif -%}

    <div class="hero-video-banner__overlay" aria-hidden="true"></div>
  </div>

  <div class="hero-video-banner__content hero-video-banner__content--{{ section.settings.text_alignment }}">
    {%- if section.settings.subheading != blank -%}
      <p class="hero-video-banner__subheading">
        {{ section.settings.subheading | escape }}
      </p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="hero-video-banner__heading">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <div class="hero-video-banner__description rte">
        {{ section.settings.description }}
      </div>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a
        {% if section.settings.button_link != blank %}
          href="{{ section.settings.button_link }}"
        {% endif %}
        class="hero-video-banner__button hero-video-banner__button--{{ section.settings.button_style }}"
        {% if section.settings.button_link == blank %}
          role="link" aria-disabled="true"
        {% endif %}
      >
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .hero-video-banner {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    width: 100%;
  }

  .hero-video-banner--full-height {
    min-height: 100svh;
  }

  .hero-video-banner--auto-height {
    min-height: 60svh;
  }

  .hero-video-banner__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-video-banner__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-video-banner__video--external {
    border: none;
    pointer-events: none;
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: 177.78vh;
    height: 56.25vw;
    transform: translate(-50%, -50%);
  }

  .hero-video-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-video-banner__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-video-banner__overlay {
    position: absolute;
    inset: 0;
    background-color: rgb(0 0 0 / var(--overlay-opacity));
    z-index: 1;
  }

  .hero-video-banner__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
    max-width: 800px;
    padding: 3rem 1.5rem;
    color: #fff;
  }

  .hero-video-banner__content--left {
    align-items: flex-start;
    text-align: left;
    margin-right: auto;
    margin-left: clamp(1.5rem, 5vw, 6rem);
  }

  .hero-video-banner__content--center {
    align-items: center;
    text-align: center;
    margin-inline: auto;
  }

  .hero-video-banner__content--right {
    align-items: flex-end;
    text-align: right;
    margin-left: auto;
    margin-right: clamp(1.5rem, 5vw, 6rem);
  }

  .hero-video-banner__subheading {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin: 0 0 1rem;
    opacity: 0.85;
    font-weight: 400;
  }

  .hero-video-banner__heading {
    font-size: clamp(2rem, 5vw, 4.5rem);
    line-height: 1.1;
    margin: 0 0 1.25rem;
    font-weight: 300;
    letter-spacing: -0.02em;
  }

  .hero-video-banner__description {
    font-size: clamp(0.875rem, 1.5vw, 1.125rem);
    line-height: 1.6;
    margin: 0 0 2rem;
    opacity: 0.9;
    max-width: 560px;
  }

  .hero-video-banner__button {
    display: inline-block;
    padding: 0.875rem 2.5rem;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-decoration: none;
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
    cursor: pointer;
  }

  .hero-video-banner__button--primary {
    background-color: #fff;
    color: #000;
    border: 1px solid #fff;
  }

  .hero-video-banner__button--primary:hover {
    background-color: transparent;
    color: #fff;
  }

  .hero-video-banner__button--secondary {
    background-color: transparent;
    color: #fff;
    border: 1px solid #fff;
  }

  .hero-video-banner__button--secondary:hover {
    background-color: #fff;
    color: #000;
  }

  .hero-video-banner__button[aria-disabled="true"] {
    opacity: 0.5;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .hero-video-banner__content--left,
    .hero-video-banner__content--right {
      margin-inline: auto;
      align-items: center;
      text-align: center;
    }

    .hero-video-banner__content {
      padding: 2rem 1.25rem;
    }

    .hero-video-banner__subheading {
      font-size: 0.6875rem;
    }

    .hero-video-banner__button {
      padding: 0.75rem 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.hero_video_banner",
  "tag": "section",
  "class": "hero-video-banner-wrapper section-wrapper",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.media"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:settings.video"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "label": "t:settings.video_url",
      "info": "t:info.video_external"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:settings.image",
      "info": "t:info.fallback_image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:settings.overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "header",
      "content": "t:content.text"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "t:settings.alignment",
      "options": [
        { "value": "left", "label": "t:options.left" },
        { "value": "center", "label": "t:options.center" },
        { "value": "right", "label": "t:options.right" }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:settings.subheading",
      "default": "New collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Tell your brand story through video"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:settings.description"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:settings.label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:settings.link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:settings.style",
      "options": [
        { "value": "primary", "label": "t:options.primary" },
        { "value": "secondary", "label": "t:options.secondary" }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "full_height",
      "label": "t:settings.full_height",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:names.hero_video_banner",
      "category": "t:categories.banners",
      "settings": {
        "text_alignment": "center",
        "overlay_opacity": 30,
        "full_height": true,
        "subheading": "New collection",
        "heading": "Tell your brand story through video",
        "button_label": "Shop now",
        "button_style": "primary"
      }
    }
  ]
}
{% endschema %}
