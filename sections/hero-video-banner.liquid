{%- assign slide_count = section.blocks.size -%}
{%- assign autoplay = section.settings.autoplay -%}
{%- assign autoplay_speed = section.settings.autoplay_speed | times: 1000 -%}

{%- if slide_count == 0 -%}
  {%- if request.design_mode -%}
    <div style="padding:60px 24px;text-align:center;background:#f5f5f5;color:#888;font-size:1rem;">
      Add slides using the "Add slide" button in the theme editor.
    </div>
  {%- endif -%}
{%- else -%}

<style>
  .rn-hero {
    position: relative;
    overflow: hidden;
    width: 100%;
    background: #000;
  }
  .rn-hero__track {
    display: flex;
    transition: transform 0.6s cubic-bezier(.4,0,.2,1);
    will-change: transform;
  }
  /* Images always show fully — no cropping on any device */
  /* Desktop: cover fills full width, anchored top so heads never crop */
  .rn-hero__slide img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: top center;
  }
  .rn-hero__slide {
    position: relative;
    min-width: 100%;
    width: 100%;
    flex-shrink: 0;
    min-height: 75vh;
  }
  /* Full height mode */
  .rn-hero__slide--full {
    min-height: 100vh;
  }
  /* Mobile: let image flow at natural height — no cropping */
  @media (max-width: 768px) {
    .rn-hero__slide {
      min-height: unset;
    }
    .rn-hero__slide--full {
      min-height: unset;
    }
    .rn-hero__slide img {
      height: auto;
      object-fit: contain;
      object-position: top center;
    }
  }

  /* Overlay */
  .rn-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,var(--overlay-opacity, 0.3));
    pointer-events: none;
  }

  /* Content */
  .rn-hero__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: var(--align-h, center);
    justify-content: var(--align-v, center);
    padding: 40px 48px;
    text-align: var(--text-align, center);
    pointer-events: none;
  }
  .rn-hero__content > * { pointer-events: auto; }
  .rn-hero__heading {
    font-size: clamp(1.8rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0 0 16px;
    line-height: 1.1;
    text-shadow: 0 2px 12px rgba(0,0,0,0.4);
  }
  .rn-hero__subheading {
    font-size: clamp(0.9rem, 2vw, 1.15rem);
    color: rgba(255,255,255,0.9);
    margin: 0 0 28px;
    max-width: 520px;
    text-shadow: 0 1px 6px rgba(0,0,0,0.4);
  }
  .rn-hero__btn {
    display: inline-block;
    padding: 14px 36px;
    border: 2px solid #fff;
    color: #fff;
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: background 0.2s, color 0.2s;
    background: transparent;
  }
  .rn-hero__btn:hover { background: #fff; color: #111; }
  .rn-hero__btn--solid { background: #fff; color: #111; }
  .rn-hero__btn--solid:hover { background: transparent; color: #fff; }

  /* Arrows */
  .rn-hero__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(255,255,255,0.15);
    border: none;
    color: #fff;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s;
    backdrop-filter: blur(4px);
  }
  .rn-hero__arrow:hover { background: rgba(255,255,255,0.35); }
  .rn-hero__arrow--prev { left: 16px; }
  .rn-hero__arrow--next { right: 16px; }
  .rn-hero__arrow svg { width: 22px; height: 22px; }

  /* Dots */
  .rn-hero__dots {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 10;
  }
  .rn-hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.5);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }
  .rn-hero__dot.active {
    background: #fff;
    transform: scale(1.3);
  }

  @media (max-width: 768px) {
    .rn-hero__content { padding: 24px 20px; }
    .rn-hero__arrow { width: 36px; height: 36px; }
    .rn-hero__slide { min-height: unset !important; }
    .rn-hero__slide img { width: 100% !important; height: auto !important; max-height: none !important; }
    .rn-hero__heading { font-size: clamp(1.2rem, 6vw, 2rem); }
    .rn-hero__subheading { font-size: 0.85rem; }
    .rn-hero__btn { padding: 10px 24px; font-size: 0.75rem; }
  }
</style>

<section class="rn-hero" id="rn-hero-{{ section.id }}"
  data-autoplay="{{ autoplay }}"
  data-speed="{{ autoplay_speed }}"
  data-count="{{ slide_count }}">

  <div class="rn-hero__track" id="rn-hero-track-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- assign overlay_op = block.settings.overlay_opacity | divided_by: 100.0 -%}
      {%- assign h_align = 'center' -%}
      {%- assign v_align = 'center' -%}
      {%- assign t_align = 'center' -%}
      {%- if block.settings.text_position == 'left' -%}{%- assign h_align = 'flex-start' -%}{%- assign t_align = 'left' -%}{%- endif -%}
      {%- if block.settings.text_position == 'right' -%}{%- assign h_align = 'flex-end' -%}{%- assign t_align = 'right' -%}{%- endif -%}
      {%- if block.settings.vertical_position == 'top' -%}{%- assign v_align = 'flex-start' -%}{%- endif -%}
      {%- if block.settings.vertical_position == 'bottom' -%}{%- assign v_align = 'flex-end' -%}{%- endif -%}

      <div class="rn-hero__slide{% if section.settings.full_height %} rn-hero__slide--full{% endif %}"
           {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{- block.settings.image | image_url: width: 2000 | image_tag:
              loading: forloop.first | iif: 'eager', 'lazy',
              fetchpriority: forloop.first | iif: 'high', 'auto',
              widths: '600,900,1200,1600,2000',
              sizes: '100vw',
              alt: block.settings.image.alt | default: block.settings.heading | escape -}}
        {%- else -%}
          {%- if request.design_mode -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        {%- endif -%}

        <div class="rn-hero__overlay" style="--overlay-opacity: {{ overlay_op }};"></div>

        {%- if block.settings.heading != blank or block.settings.subheading != blank or block.settings.button_label != blank -%}
          <div class="rn-hero__content"
               style="--align-h:{{ h_align }};--align-v:{{ v_align }};--text-align:{{ t_align }};">
            {%- if block.settings.heading != blank -%}
              <h2 class="rn-hero__heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.subheading != blank -%}
              <p class="rn-hero__subheading">{{ block.settings.subheading }}</p>
            {%- endif -%}
            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_link | default: '#' }}"
                 class="rn-hero__btn{% if block.settings.button_style == 'solid' %} rn-hero__btn--solid{% endif %}">
                {{ block.settings.button_label }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  {%- if slide_count > 1 -%}
    {%- if section.settings.show_arrows -%}
      <button class="rn-hero__arrow rn-hero__arrow--prev" aria-label="Previous slide">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="rn-hero__arrow rn-hero__arrow--next" aria-label="Next slide">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    {%- endif -%}

    {%- if section.settings.show_dots -%}
      <div class="rn-hero__dots" id="rn-hero-dots-{{ section.id }}">
        {%- for block in section.blocks -%}
          <button class="rn-hero__dot{% if forloop.first %} active{% endif %}" aria-label="Go to slide {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}

</section>

<script>
(function() {
  var hero = document.getElementById('rn-hero-{{ section.id }}');
  if (!hero) return;
  var track = document.getElementById('rn-hero-track-{{ section.id }}');
  var dots  = hero.querySelectorAll('.rn-hero__dot');
  var prev  = hero.querySelector('.rn-hero__arrow--prev');
  var next  = hero.querySelector('.rn-hero__arrow--next');
  var total = parseInt(hero.dataset.count) || 1;
  var current = 0;
  var autoplay = hero.dataset.autoplay === 'true';
  var speed = parseInt(hero.dataset.speed) || 5000;
  var timer = null;

  function goTo(idx) {
    if (idx < 0) idx = total - 1;
    if (idx >= total) idx = 0;
    current = idx;
    track.style.transform = 'translateX(-' + (100 * current) + '%)';
    dots.forEach(function(d, i) { d.classList.toggle('active', i === current); });
  }

  if (prev) prev.addEventListener('click', function() { stopAuto(); goTo(current - 1); startAuto(); });
  if (next) next.addEventListener('click', function() { stopAuto(); goTo(current + 1); startAuto(); });
  dots.forEach(function(d, i) {
    d.addEventListener('click', function() { stopAuto(); goTo(i); startAuto(); });
  });

  // Touch/swipe support
  var touchStartX = 0;
  hero.addEventListener('touchstart', function(e) { touchStartX = e.touches[0].clientX; }, { passive: true });
  hero.addEventListener('touchend', function(e) {
    var dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 40) { stopAuto(); goTo(dx < 0 ? current + 1 : current - 1); startAuto(); }
  }, { passive: true });

  function startAuto() {
    if (!autoplay || total < 2) return;
    stopAuto();
    timer = setInterval(function() { goTo(current + 1); }, speed);
  }
  function stopAuto() { clearInterval(timer); }

  startAuto();
})();
</script>

{%- endif -%}

{% schema %}
{
  "name": "Hero Image Carousel",
  "tag": "section",
  "class": "hero-carousel-wrapper",
  "max_blocks": 10,
  "settings": [
    {
      "type": "checkbox",
      "id": "full_height",
      "label": "Full screen height",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show prev/next arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dot indicators",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-play",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Auto-play speed (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay darkness",
          "min": 0,
          "max": 70,
          "step": 5,
          "default": 20,
          "unit": "%"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "New Season Arrivals"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            { "value": "outline", "label": "Outline (white border)" },
            { "value": "solid", "label": "Solid (white fill)" }
          ],
          "default": "outline"
        },
        {
          "type": "select",
          "id": "text_position",
          "label": "Text alignment",
          "options": [
            { "value": "left",   "label": "Left"   },
            { "value": "center", "label": "Center" },
            { "value": "right",  "label": "Right"  }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "vertical_position",
          "label": "Vertical position",
          "options": [
            { "value": "top",    "label": "Top"    },
            { "value": "middle", "label": "Middle" },
            { "value": "bottom", "label": "Bottom" }
          ],
          "default": "middle"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Image Carousel",
      "blocks": [
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}